# Agent Communication Protocol — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.

# ── Security ─────────────────────────────────────────────────────────
# HMAC signing secret for agent identity tokens (use RS256 in production)
ACP_SIGNING_SECRET=change-me-to-a-long-random-secret-in-production

# Token TTL in seconds (default: 3600 = 1 hour)
ACP_TOKEN_TTL_SECONDS=3600

# Maximum delegation depth to prevent infinite recursion (default: 3)
ACP_MAX_DELEGATION_DEPTH=3

# ── Memory ────────────────────────────────────────────────────────────
# Redis URL for distributed memory (optional — falls back to in-process)
REDIS_URL=redis://localhost:6379/0

# Vector store URL for semantic memory (optional — falls back to keyword search)
VECTOR_STORE_URL=http://localhost:6333

# ── Observability ─────────────────────────────────────────────────────
# OTLP endpoint for OpenTelemetry span export (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING

# ── MCP Tool Backends ─────────────────────────────────────────────────
# Search API key (for real web_search tool backend)
SEARCH_API_KEY=

# Database connection string (for real database_query tool)
DATABASE_URL=postgresql://user:pass@localhost:5432/agents

# ── ANP / DID ─────────────────────────────────────────────────────────
# Organization DID (for ANP decentralized identity)
ORG_DID=did:web:agents.your-org.com

# ── Environment ───────────────────────────────────────────────────────
ENVIRONMENT=development
ORGANIZATION=default
